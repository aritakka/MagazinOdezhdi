<Window x:Class="ClothingStoreNew.Controls.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="250" Width="300">

    <StackPanel Margin="20">
        <TextBlock Text="Email:"/>
        <TextBox x:Name="EmailBox" Margin="5"/>

        <TextBlock Text="Пароль:"/>
        <PasswordBox x:Name="PasswordBox" Margin="5"/>

        <Button Content="Войти" Click="Login_Click" Margin="5"/>
        <Button Content="Регистрация" Click="Register_Click" Margin="5"/>
    </StackPanel>
</Window>