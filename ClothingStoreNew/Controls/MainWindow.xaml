<Window x:Class="ClothingStoreNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин" Height="650" Width="1100">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- 🔝 ВЕРХ + ФИЛЬТРЫ -->
        <StackPanel Margin="10">

            <!-- КНОПКИ -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Корзина"
                        Width="120"
                        Margin="5"
                        Click="Cart_Click"/>

                <Button Content="Админ панель"
                        Width="150"
                        Margin="5"
                        Visibility="{Binding AdminVisibility}"
                        Click="Admin_Click"/>
            </StackPanel>

            <!-- 🔍 ФИЛЬТРЫ -->
            <StackPanel Orientation="Horizontal" Margin="5">

                <TextBox x:Name="SearchBox"
                         Width="200"
                         Margin="5"
                         VerticalAlignment="Center"
                         TextChanged="Filter_Changed"
                         ToolTip="Поиск по названию"/>

                <ComboBox x:Name="CategoryFilter"
                          Width="150"
                          Margin="5"
                          DisplayMemberPath="Name"
                          SelectionChanged="Filter_Changed"/>

                <TextBox x:Name="MinPriceBox"
                         Width="80"
                         Margin="5"
                         TextChanged="Filter_Changed"
                         ToolTip="Мин цена"/>

                <TextBox x:Name="MaxPriceBox"
                         Width="80"
                         Margin="5"
                         TextChanged="Filter_Changed"
                         ToolTip="Макс цена"/>

            </StackPanel>

        </StackPanel>

        <!-- 🛍 ТОВАРЫ -->
        <ScrollViewer Grid.Row="1">

            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Width="200"
                                Margin="10"
                                Padding="10"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="8">

                            <StackPanel>

                                <Image Width="160"
                                       Height="160"
                                       Stretch="UniformToFill"
                                       Source="{Binding ImagePath}"/>

                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding Price, StringFormat={}{0} ₽}"
                                           Foreground="Green"
                                           Margin="0,5"/>

                                <Button Content="В корзину"
                                        Tag="{Binding}"
                                        Click="AddToCart_Click"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>
</Window>