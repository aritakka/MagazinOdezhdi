<Window x:Class="ClothingStoreNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог" Height="600" Width="900">

    <DockPanel>

        <!-- TOP -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="10">

            <Button Content="🛒 Корзина"
                    Click="Cart_Click"
                    Margin="5"/>

            <Button Content="⚙ Админ"
                    Click="Admin_Click"
                    Margin="5"
                    Visibility="{Binding AdminVisibility}"/>

        </StackPanel>

        <!-- PRODUCTS -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10" Width="180">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextAlignment="Center"/>
                                <TextBlock Text="{Binding Price}" Foreground="Green" TextAlignment="Center"/>
                                <Button Content="В корзину"
                                        Click="AddToCart_Click"
                                        Tag="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>