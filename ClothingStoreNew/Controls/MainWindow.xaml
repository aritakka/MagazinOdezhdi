<Window x:Class="ClothingStoreNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог" Height="600" Width="900">

    <DockPanel>

        <!-- Верх -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="10">

            <Button Content="🛒 Корзина"
                    Click="OpenCart_Click"
                    Margin="0,0,10,0"/>

            <TextBlock Text="{Binding CartCount}"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </StackPanel>

        <!-- Товары -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Products}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                Margin="10"
                                Padding="10"
                                Width="180">

                            <StackPanel>

                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>

                                <TextBlock Text="{Binding Price}"
                                           Foreground="Green"
                                           TextAlignment="Center"/>

                                <Button Content="В корзину"
                                        Click="AddToCart_Click"
                                        Tag="{Binding}" />

                                <!-- админ кнопка -->
                                <Button Content="Изменить цену"
                                        Click="EditPrice_Click"
                                        Tag="{Binding}"
                                        x:Name="AdminBtn"
                                        Visibility="Collapsed"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>