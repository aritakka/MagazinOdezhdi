<Window x:Class="ClothingStoreNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин" Height="650" Width="1100">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL -->
        <StackPanel Orientation="Horizontal" Margin="10">

            <Button Content="Корзина"
                    Width="120"
                    Margin="5"
                    Click="Cart_Click"/>

            <Button Content="Админ панель"
                    Width="150"
                    Margin="5"
                    Visibility="{Binding AdminVisibility}"
                    Click="Admin_Click"/>

        </StackPanel>

        <!-- PRODUCTS -->
        <ScrollViewer Grid.Row="1">

            <ItemsControl ItemsSource="{Binding Products}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Width="200"
                                Margin="10"
                                Padding="10"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="8">

                            <StackPanel>

                                <!-- IMAGE -->
                                <Image Width="160"
                                       Height="160"
                                       Stretch="UniformToFill"
                                       Source="{Binding ImagePath}"/>

                                <!-- NAME -->
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>

                                <!-- PRICE -->
                                <TextBlock Text="{Binding Price, StringFormat={}{0} ₽}"
                                           Foreground="Green"
                                           Margin="0,5"/>

                                <!-- BUTTON -->
                                <Button Content="В корзину"
                                        Tag="{Binding}"
                                        Click="AddToCart_Click"
                                        Margin="0,5"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>
</Window>