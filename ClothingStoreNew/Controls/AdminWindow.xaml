<Window x:Class="ClothingStoreNew.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Админ панель" Height="650" Width="1100">

    <Grid>
        <TabControl>

            <!-- ================= PRODUCTS ================= -->
            <TabItem Header="Товары">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="ProductsGrid"
                              AutoGenerateColumns="True"
                              SelectionChanged="ProductsGrid_SelectionChanged"
                              Grid.Column="0"
                              Margin="0,0,10,0"/>

                    <StackPanel Grid.Column="1">

                        <TextBlock Text="Название"/>
                        <TextBox x:Name="NameBox"/>

                        <TextBlock Text="Цена"/>
                        <TextBox x:Name="PriceBox"/>

                        <TextBlock Text="Описание"/>
                        <TextBox x:Name="DescriptionBox"/>

                        <TextBlock Text="Категория"/>
                        <ComboBox x:Name="CategoryBox"
                                  DisplayMemberPath="Name"
                                  Margin="0,5"/>

                        <TextBlock Text="Бренд"/>
                        <ComboBox x:Name="BrandBox"
                                  DisplayMemberPath="Name"
                                  Margin="0,5"/>

                        <Button Content="Выбрать изображение"
                                Click="SelectImage_Click"
                                Margin="5"/>

                        <TextBlock x:Name="ImagePathText"
                                   Text="Файл не выбран"
                                   TextWrapping="Wrap"
                                   Margin="5"/>

                        <TextBlock Text="Наличие"/>
                        <TextBox x:Name="StockBox"/>

                        <Button Content="Добавить" Click="AddProduct"/>
                        <Button Content="Обновить" Click="UpdateProduct"/>
                        <Button Content="Удалить" Click="DeleteProduct"/>

                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ================= USERS ================= -->
            <TabItem Header="Пользователи">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="UsersGrid"
                              AutoGenerateColumns="True"
                              Grid.Column="0"
                              Margin="0,0,10,0"/>

                    <StackPanel Grid.Column="1">

                        <TextBlock Text="Email"/>
                        <TextBox x:Name="NewEmailBox"/>

                        <TextBlock Text="ФИО"/>
                        <TextBox x:Name="NewNameBox"/>

                        <TextBlock Text="Пароль"/>
                        <TextBox x:Name="NewPasswordBox"/>

                        <Button Content="Добавить" Click="AddUser"/>

                        <TextBlock Text="Роль"/>
                        <ComboBox x:Name="RoleBox">
                            <ComboBoxItem Content="User"/>
                            <ComboBoxItem Content="Admin"/>
                        </ComboBox>

                        <Button Content="Сменить роль" Click="ChangeRole"/>
                        <Button Content="Удалить" Click="DeleteUser"/>

                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ================= ORDERS ================= -->
            <TabItem Header="Заказы">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="OrdersGrid"
                              AutoGenerateColumns="True"
                              SelectionChanged="OrdersGrid_SelectionChanged"/>

                    <DataGrid x:Name="OrderItemsGrid"
                              Grid.Column="1"
                              AutoGenerateColumns="True"/>

                    <StackPanel Grid.Column="2">

                        <TextBlock Text="Пользователь"/>
                        <TextBlock x:Name="OrderUserText"/>

                        <TextBlock Text="Сумма"/>
                        <TextBlock x:Name="OrderTotalText"/>

                        <TextBlock Text="Статус"/>
                        <ComboBox x:Name="OrderStatusBox">
                            <ComboBoxItem Content="Новый"/>
                            <ComboBoxItem Content="В обработке"/>
                            <ComboBoxItem Content="Отправлен"/>
                            <ComboBoxItem Content="Завершён"/>
                            <ComboBoxItem Content="Отменён"/>
                        </ComboBox>

                        <Button Content="Обновить" Click="UpdateOrderStatus"/>

                    </StackPanel>

                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>