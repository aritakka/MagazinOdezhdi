<Window x:Class="ClothingStoreNew.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Админ панель"
        Height="650"
        Width="1100"
        Background="#F5F7FB">

    <Grid Margin="10">

        <TabControl Background="Transparent">

            <!-- ================= PRODUCTS ================= -->
            <TabItem Header="Товары">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="ProductsGrid"
                              Grid.Column="0"
                              Margin="0,0,10,0"
                              AutoGenerateColumns="True"
                              Background="White"
                              SelectionChanged="ProductsGrid_SelectionChanged"/>

                    <Border Grid.Column="1"
                            Background="White"
                            Padding="15"
                            CornerRadius="10">

                        <StackPanel>

                            <TextBlock Text="Название"/>
                            <TextBox x:Name="NameBox"/>

                            <TextBlock Text="Цена"/>
                            <TextBox x:Name="PriceBox"/>

                            <TextBlock Text="Описание"/>
                            <TextBox x:Name="DescriptionBox"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>

                            <TextBlock Text="Категория"/>
                            <ComboBox x:Name="CategoryBox"
                                      DisplayMemberPath="Name"/>

                            <TextBlock Text="Бренд"/>
                            <ComboBox x:Name="BrandBox"
                                      DisplayMemberPath="Name"/>

                            <Button Content="Выбрать изображение"
                                    Click="SelectImage_Click"/>

                            <TextBlock x:Name="ImagePathText"
                                       Text="Файл не выбран"
                                       Foreground="Gray"/>

                            <TextBlock Text="Наличие"/>
                            <TextBox x:Name="StockBox"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Button Content="Добавить"
                                        Click="AddProduct"/>

                                <Button Content="Обновить"
                                        Click="UpdateProduct"/>

                                <Button Content="Удалить"
                                        Background="#EF4444"
                                        Click="DeleteProduct"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>

                </Grid>
            </TabItem>

            <!-- ================= USERS ================= -->
            <TabItem Header="Пользователи">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="UsersGrid"
                              Grid.Column="0"
                              AutoGenerateColumns="True"
                              Background="White"/>

                    <Border Grid.Column="1"
                            Background="White"
                            Padding="15">

                        <StackPanel>

                            <TextBlock Text="Email"/>
                            <TextBox x:Name="NewEmailBox"/>

                            <TextBlock Text="ФИО"/>
                            <TextBox x:Name="NewNameBox"/>

                            <TextBlock Text="Пароль"/>
                            <TextBox x:Name="NewPasswordBox"/>

                            <Button Content="Добавить"
                                    Click="AddUser"/>

                            <TextBlock Text="Роль"/>
                            <ComboBox x:Name="RoleBox">
                                <ComboBoxItem Content="User"/>
                                <ComboBoxItem Content="Admin"/>
                            </ComboBox>

                            <Button Content="Сменить роль"
                                    Click="ChangeRole"/>

                            <Button Content="Удалить"
                                    Background="#EF4444"
                                    Click="DeleteUser"/>

                        </StackPanel>

                    </Border>

                </Grid>
            </TabItem>

            <!-- ================= ORDERS ================= -->
            <TabItem Header="Заказы">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="OrdersGrid"
                              Grid.Column="0"
                              AutoGenerateColumns="True"
                              SelectionChanged="OrdersGrid_SelectionChanged"/>

                    <DataGrid x:Name="OrderItemsGrid"
                              Grid.Column="1"
                              AutoGenerateColumns="True"/>

                    <Border Grid.Column="2"
                            Background="White"
                            Padding="15">

                        <StackPanel>

                            <TextBlock Text="Пользователь"/>
                            <TextBlock x:Name="OrderUserText"/>

                            <TextBlock Text="Сумма"/>
                            <TextBlock x:Name="OrderTotalText"/>

                            <TextBlock Text="Статус"/>

                            <ComboBox x:Name="OrderStatusBox">
                                <ComboBoxItem Content="Новый"/>
                                <ComboBoxItem Content="В обработке"/>
                                <ComboBoxItem Content="Отправлен"/>
                                <ComboBoxItem Content="Завершён"/>
                                <ComboBoxItem Content="Отменён"/>
                            </ComboBox>

                            <Button Content="Обновить"
                                    Click="UpdateOrderStatus"/>

                        </StackPanel>

                    </Border>

                </Grid>
            </TabItem>

        </TabControl>

    </Grid>
</Window>