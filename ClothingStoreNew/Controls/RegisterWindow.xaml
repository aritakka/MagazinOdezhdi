<Window x:Class="ClothingStoreNew.Controls.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="300" Width="300">

    <StackPanel Margin="20">

        <TextBlock Text="Email:"/>
        <TextBox x:Name="EmailBox" Margin="5"/>

        <TextBlock Text="ФИО:"/>
        <TextBox x:Name="NameBox" Margin="5"/>

        <TextBlock Text="Пароль:"/>
        <PasswordBox x:Name="PasswordBox" Margin="5"/>

        <Button Content="Зарегистрироваться" Click="Register_Click" Margin="5"/>

    </StackPanel>
</Window>