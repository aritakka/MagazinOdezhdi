<Window x:Class="ClothingStoreNew.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="520"
        Width="420"
        Background="#F5F7FB">

    <Border Background="White"
            Padding="15"
            Margin="10"
            CornerRadius="12">

        <StackPanel>

            <TextBlock Text="Название"/>
            <TextBox x:Name="NameBox"/>

            <TextBlock Text="Цена"/>
            <TextBox x:Name="PriceBox"/>

            <TextBlock Text="Категория"/>
            <ComboBox x:Name="CategoryBox"
                      DisplayMemberPath="Name"/>

            <TextBlock Text="Бренд"/>
            <ComboBox x:Name="BrandBox"
                      DisplayMemberPath="Name"/>

            <!-- ================= IMAGE ================= -->
            <TextBlock Text="Изображение" Margin="0,10,0,0"/>

            <Image x:Name="PreviewImage"
                   Height="140"
                   Stretch="UniformToFill"
                   Margin="0,5"
                   />

            <TextBlock x:Name="ImagePathText"
                       Text="Нет изображения"
                       Foreground="Gray"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal">

                <Button Content="Выбрать"
                        Click="SelectImage_Click"/>

                <Button Content="Удалить"
                        Background="#EF4444"
                        Click="RemoveImage_Click"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,10,0,0">

                <Button Content="Сохранить"
                        Click="Save_Click"/>

                <Button Content="Удалить товар"
                        Background="#EF4444"
                        Click="Delete_Click"/>

            </StackPanel>

        </StackPanel>

    </Border>

</Window>