<Application x:Class="ClothingStoreNew.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClothingStoreNew"
             StartupUri="Controls/LoginWindow.xaml">

    <Application.Resources>

        <!-- ================= COLORS ================= -->
        <Color x:Key="PrimaryColor">#4F46E5</Color>
        <Color x:Key="BgColor">#F5F7FB</Color>
        <Color x:Key="CardColor">#FFFFFF</Color>
        <Color x:Key="TextDark">#111827</Color>
        <Color x:Key="Success">#22C55E</Color>
        <Color x:Key="Danger">#EF4444</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextDark}"/>

        <!-- ================= WINDOW BACKGROUND ================= -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- ================= BUTTONS ================= -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ================= TEXTBOX ================= -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ================= COMBOBOX ================= -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ================= DATA GRID ================= -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>

        <!-- ================= IMAGE CONVERTER ================= -->
        <local:ImagePathConverter x:Key="ImageConverter"/>

    </Application.Resources>

</Application>